{
  "name": "ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "build-dev": "vite build -h",
    "generate-api-client": "openapi-ts",
    "generate-docs": "redocly build-docs ../openapi.yaml --output public/docs/index.html"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@mdi/js": "^7.4.47",
    "axios": "^1.15.2",
    "hls.js": "^1.6.16",
    "lodash.debounce": "^4.0.8",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.33",
    "vue-axios": "^3.5.2",
    "vue-router": "^5.0.6",
    "vuetify": "^4.0.6"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.96.1",
    "@redocly/cli": "^2.30.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "1.6.16",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
